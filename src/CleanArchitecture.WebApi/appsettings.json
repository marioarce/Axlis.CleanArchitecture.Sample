{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PowerFeatures": {
    "Cors": {
      "Enabled": true,
      "PolicyName": "DefaultCors",
      "AllowedOrigins": [ "https://localhost" ]
    },
    "Cache": {
      "Enabled": true,
      "Provider": "BitFaster",
      "Capacity": 1000
    }
  }
}
